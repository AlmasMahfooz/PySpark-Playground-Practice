# Initialize Spark session
from pyspark.sql import SparkSession
from pyspark.sql.functions import col
spark = SparkSession.builder.appName('Spark Playground').getOrCreate()

# Load the customers.csv dataset
#df = spark.read.format('csv').option('header', 'true').load('/samples/customers.csv')
#df2 = spark.read.format('csv').option('header', 'true').load('/samples/sales.csv')
#dfproducts=spark.read.format('csv').option('header', 'true').load('/samples/products.csv')

df_json = spark.read.option("multiline", "true").json('/samples/products.json')

# Create a temporary SQL view (instead of saveAsTable)
df_json.createOrReplaceTempView("my_json_table")

# Query it immediately with SQL
df_checked = spark.sql("SELECT * FROM my_json_table")
display(df_checked)
